# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash logs
crash.log

# Override files
override.tf
override.tf.json

# --- Ajouts recommandés pour ton projet spécifique ---

# Fichiers de variables contenant des données sensibles (ex: terraform.tfvars)
# On garde .tfvars.example pour documenter, mais on ignore les vrais fichiers de valeurs
*.tfvars
*.tfvars.json

# Ignorer explicitement les backups d'état présents à la racine de ton projet
*.tfstate.backup

# Fichiers de configuration utilisateur CLI de Terraform
.terraformrc
terraform.rc